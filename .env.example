#  Flask Backend 
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wildfire_db
DB_USER=postgres
DB_PASSWORD=root
SECRET_KEY=wildfire-super-secret-key-2026

# External APIs
# FIRMS Map Key — get yours at https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Limit: 5000 transactions / 10 minutes (larger requests count as multiple)
FIRMS_API_KEY=your_firms_api_key

#  PostgreSQL Container (must match DB_* above)
POSTGRES_DB=wildfire_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root